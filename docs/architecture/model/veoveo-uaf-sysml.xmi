  <UAF:System xmi:id="VV-SYS-001-UAF" base_Class="VV-SYS-001" />
  <SysML:Block xmi:id="VV-SYS-001-SYSML" base_Class="VV-SYS-001" isEncapsulated="true" />
  <UAF:ActualResource xmi:id="VV-AR-001-UAF" base_InstanceSpecification="VV-AR-001" />
  <UAF:ActualResource xmi:id="VV-AR-002-UAF" base_InstanceSpecification="VV-AR-002" />
  <UAF:ActualResource xmi:id="VV-AR-003-UAF" base_InstanceSpecification="VV-AR-003" />
  <UAF:ActualResource xmi:id="VV-AR-004-UAF" base_InstanceSpecification="VV-AR-004" />
