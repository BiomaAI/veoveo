  <UAF:OperationalPerformer xmi:id="VV-EXT-BROWSER-UAF" base_Class="VV-EXT-BROWSER" />
  <UAF:OperationalPerformer xmi:id="VV-EXT-OAUTH-CLIENT-UAF" base_Class="VV-EXT-OAUTH-CLIENT" />
  <UAF:OperationalPerformer xmi:id="VV-EXT-AUTHORIZED-USER-UAF" base_Class="VV-EXT-AUTHORIZED-USER" />
  <UAF:OperationalPerformer xmi:id="VV-EXT-LINK-HOLDER-UAF" base_Class="VV-EXT-LINK-HOLDER" />
  <UAF:OperationalPerformer xmi:id="VV-EXT-PRODUCER-UAF" base_Class="VV-EXT-PRODUCER" />
  <UAF:OperationalPerformer xmi:id="VV-CMP-HOSTED-UAF" base_Class="VV-CMP-HOSTED" />
  <UAF:OperationalPerformer xmi:id="VV-CMP-PLATFORM-UAF" base_Class="VV-CMP-PLATFORM" />
  <SysML:Requirement xmi:id="VV-REQ-001-SYSML" base_Class="VV-REQ-001" id="VV-REQ-001" text="Each installation shall remain organization-owned and shall not depend on a Veoveo vendor control plane, hosted service, or canonical domain name." />
  <SysML:Requirement xmi:id="VV-REQ-002-SYSML" base_Class="VV-REQ-002" id="VV-REQ-002" text="Hosted domains shall use the complete MCP protocol surface where it fits, including resources, templates, prompts, completions, tasks, subscriptions, notifications, structured content, and URI identities." />
  <SysML:Requirement xmi:id="VV-REQ-003-SYSML" base_Class="VV-REQ-003" id="VV-REQ-003" text="Every externally reachable MCP or administrative operation shall pass through profile selection, policy evaluation, and audit at the gateway." />
  <SysML:Requirement xmi:id="VV-REQ-004-SYSML" base_Class="VV-REQ-004" id="VV-REQ-004" text="Provider job completion shall be accepted only from a signed provider webhook and shall never poll provider status." />
  <SysML:Requirement xmi:id="VV-REQ-005-SYSML" base_Class="VV-REQ-005" id="VV-REQ-005" text="Long-running operations shall use one durable task authority with explicit idempotency, leases, recovery class, cancellation, results, retention, and ordered event delivery." />
  <SysML:Requirement xmi:id="VV-REQ-006-SYSML" base_Class="VV-REQ-006" id="VV-REQ-006" text="Artifact occurrences and bytes shall remain tenant-isolated and shall enforce labels, grants, release state, retention, and bounded sharing." />
  <SysML:Requirement xmi:id="VV-REQ-007-SYSML" base_Class="VV-REQ-007" id="VV-REQ-007" text="World and sensor producers shall push Rerun log streams into a private durable recording boundary that preserves crash-decodable evidence." />
  <SysML:Requirement xmi:id="VV-REQ-008-SYSML" base_Class="VV-REQ-008" id="VV-REQ-008" text="Perception shall run locally over authorized recorded data with bounded GPU execution and shall publish governed derived results." />
  <SysML:Requirement xmi:id="VV-REQ-009-SYSML" base_Class="VV-REQ-009" id="VV-REQ-009" text="Autonomous agents shall persist wakes, episodes, task descriptors, retries, results, and retention pins across process restart." />
  <SysML:Requirement xmi:id="VV-REQ-010-SYSML" base_Class="VV-REQ-010" id="VV-REQ-010" text="Browser JavaScript shall never receive the gateway bearer and every unsafe console request shall enforce CSRF." />
  <SysML:Requirement xmi:id="VV-REQ-011-SYSML" base_Class="VV-REQ-011" id="VV-REQ-011" text="An offline installation shall verify all transferred files and images and shall not require network access during loading or operation of provider-independent capabilities." />
  <SysML:Requirement xmi:id="VV-REQ-012-SYSML" base_Class="VV-REQ-012" id="VV-REQ-012" text="Compose and Helm shall instantiate the same canonical service graph while retaining form-specific controls for storage, ingress, network policy, and mTLS." />
  <SysML:Requirement xmi:id="VV-REQ-013-SYSML" base_Class="VV-REQ-013" id="VV-REQ-013" text="Analytical users shall retain arbitrary DuckDB SQL within owner-scoped workspaces bounded by engine, filesystem, process, resource, and network controls." />
  <SysML:Requirement xmi:id="VV-REQ-014-SYSML" base_Class="VV-REQ-014" id="VV-REQ-014" text="The platform shall support governed map acquisition, release activation, restrictions, geodesy, routing, reachable areas, and logistics matrices through stable map identities." />
  <SysML:Requirement xmi:id="VV-REQ-015-SYSML" base_Class="VV-REQ-015" id="VV-REQ-015" text="Known platform and domain contracts shall use typed structs, enums, identifiers, and schemas; raw JSON shall remain confined to genuinely opaque provider boundaries." />
  <SysML:Requirement xmi:id="VV-REQ-016-SYSML" base_Class="VV-REQ-016" id="VV-REQ-016" text="Only the gateway shall sign short-lived internal identity assertions and hosted services shall validate the key identifier, audience, tenant, principal, labels, scopes, and expiry." />
  <SysML:Requirement xmi:id="VV-REQ-017-SYSML" base_Class="VV-REQ-017" id="VV-REQ-017" text="SurrealDB shall remain the sole platform coordination authority; transactional outbox replay shall remain authoritative over best-effort live delivery." />
  <SysML:Requirement xmi:id="VV-REQ-018-SYSML" base_Class="VV-REQ-018" id="VV-REQ-018" text="New hosted servers shall compose through shared contracts and the gateway catalog without leaking server-specific behavior into generic gateway modules." />
