diff --git a/cesium.omniverse/cesium/omniverse/install/vendor_install.py b/cesium.omniverse/cesium/omniverse/install/vendor_install.py
index 4a7ec4d..c65dbe3 100644
--- a/cesium.omniverse/cesium/omniverse/install/vendor_install.py
+++ b/cesium.omniverse/cesium/omniverse/install/vendor_install.py
@@ -1,24 +1,20 @@
-import logging
-from typing import List
-from .wheel_installer import WheelInfo, WheelInstaller
+from importlib import metadata


 def perform_vendor_install():
-    logger = logging.getLogger(__name__)
-
-    # Only vendor wheels for the main Cesium Omniverse extension should be placed here.
-    #  This action needs to be mirrored for each extension.
-    vendor_wheels: List[WheelInfo] = [
-        WheelInfo(
-            module="lxml",
-            windows_whl="lxml-6.0.2-cp312-cp312-win_amd64.whl",
-            linux_x64_whl="lxml-6.0.2-cp312-cp312-manylinux_2_26_x86_64.manylinux_2_28_x86_64.whl",
-            linux_aarch_whl="lxml-6.0.2-cp312-cp312-manylinux_2_26_aarch64.manylinux_2_28_aarch64.whl",
-        )
-    ]
-
-    for w in vendor_wheels:
-        installer = WheelInstaller(w)
-
-        if not installer.install():
-            logger.error(f"Could not install wheel for {w.module}")
+    """Fail closed unless the image preinstalled Cesium's bundled vendor wheel.
+
+    Veoveo images run as a non-root identity and never mutate a Kit installation
+    at startup. The Docker build installs the release-bundled wheel after its
+    archive checksum has been verified.
+    """
+    expected_version = "6.0.2"
+    try:
+        installed_version = metadata.version("lxml")
+    except metadata.PackageNotFoundError as error:
+        raise RuntimeError("Cesium's bundled lxml wheel was not preinstalled") from error
+    if installed_version != expected_version:
+        raise RuntimeError(
+            "Cesium requires its bundled lxml "
+            f"{expected_version}, found {installed_version}"
+        )
