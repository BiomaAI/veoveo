{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "global",
    "images",
    "platform",
    "recordingForwarder",
    "world",
    "cache",
    "session",
    "interactive",
    "batch",
    "service",
    "resources",
    "scheduling",
    "networkPolicy"
  ],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["production", "veoveoRegistry", "veoveoTag", "imagePullSecrets"],
      "properties": {
        "production": {"type": "boolean"},
        "veoveoRegistry": {"type": "string"},
        "veoveoTag": {"type": "string"},
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {"name": {"type": "string", "minLength": 1}}
          }
        }
      }
    },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pullPolicy", "runtime", "mcp", "forwarder"],
      "properties": {
        "pullPolicy": {"enum": ["Always", "IfNotPresent", "Never"]},
        "runtime": {"$ref": "#/definitions/image"},
        "mcp": {"$ref": "#/definitions/image"},
        "forwarder": {"$ref": "#/definitions/image"}
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instanceLabel",
        "publicBaseUrl",
        "installationSecret",
        "cesiumSecret",
        "cesiumTokenKey",
        "surrealService",
        "surrealNamespace",
        "surrealDatabase",
        "surrealRuntimeSecret",
        "recordingTenantKey"
      ],
      "properties": {
        "instanceLabel": {"type": "string", "minLength": 1},
        "publicBaseUrl": {"type": "string", "pattern": "^https?://"},
        "installationSecret": {"type": "string", "minLength": 1},
        "cesiumSecret": {"type": "string", "minLength": 1},
        "cesiumTokenKey": {"const": "cesium-ion-access-token"},
        "surrealService": {"type": "string", "minLength": 1},
        "surrealNamespace": {"type": "string", "minLength": 1},
        "surrealDatabase": {"type": "string", "minLength": 1},
        "surrealRuntimeSecret": {"type": "string", "minLength": 1},
        "recordingTenantKey": {"type": "string", "minLength": 1}
      }
    },
    "recordingForwarder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gatewayTransportUrl",
        "clientId",
        "keyId",
        "signingAlgorithm",
        "privateKey",
        "maximumQueueBytes",
        "batchMessageLimit",
        "batchFlushMilliseconds",
        "grpcMemoryLimitBytes",
        "persistence",
        "resources"
      ],
      "properties": {
        "gatewayTransportUrl": {"type": "string", "pattern": "^https?://[A-Za-z0-9._:-]+/?$"},
        "clientId": {"type": "string", "minLength": 1},
        "keyId": {"type": "string", "minLength": 1},
        "signingAlgorithm": {"enum": ["rs256", "es256", "ed-dsa"]},
        "privateKey": {
          "type": "object",
          "additionalProperties": false,
          "required": ["existingSecret", "key"],
          "properties": {
            "existingSecret": {"type": "string", "minLength": 1},
            "key": {"type": "string", "minLength": 1}
          }
        },
        "maximumQueueBytes": {"type": "integer", "minimum": 8388608},
        "batchMessageLimit": {"type": "integer", "minimum": 1, "maximum": 65536},
        "batchFlushMilliseconds": {"type": "integer", "minimum": 1, "maximum": 60000},
        "grpcMemoryLimitBytes": {"type": "integer", "minimum": 8388608},
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size", "storageClass", "accessMode"],
          "properties": {
            "size": {"type": "string", "pattern": "^[1-9][0-9]*(Ei|Pi|Ti|Gi|Mi|Ki)$"},
            "storageClass": {"type": "string"},
            "accessMode": {"enum": ["ReadWriteOnce", "ReadWriteMany"]}
          }
        },
        "resources": {"type": "object"}
      }
    },
    "world": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "cesiumIonAssetId"],
      "properties": {
        "source": {"const": "google_photorealistic_3d_tiles"},
        "cesiumIonAssetId": {"const": 2275207}
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "version", "size", "storageClass", "accessMode"],
      "properties": {
        "policy": {"enum": ["ephemeral", "persistent"]},
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "size": {
          "type": "string",
          "pattern": "^[1-9][0-9]*(Ei|Pi|Ti|Gi|Mi|Ki)$"
        },
        "storageClass": {"type": "string"},
        "accessMode": {"enum": ["ReadWriteOnce", "ReadWriteMany"]}
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "frameUri",
        "origin",
        "vehicleCount",
        "physicsHz",
        "renderingHz",
        "tileReadyFrames",
        "privacyConsent",
        "camera"
      ],
      "properties": {
        "id": {"$ref": "#/definitions/identity"},
        "frameUri": {"type": "string", "pattern": "^frames://frame/[A-Za-z0-9_.-]+$"},
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["latitudeDegrees", "longitudeDegrees", "ellipsoidHeightM"],
          "properties": {
            "latitudeDegrees": {"type": "number", "minimum": -90, "maximum": 90},
            "longitudeDegrees": {"type": "number", "minimum": -180, "maximum": 180},
            "ellipsoidHeightM": {"type": "number", "minimum": -1000, "maximum": 100000}
          }
        },
        "vehicleCount": {"type": "integer", "minimum": 1, "maximum": 16},
        "physicsHz": {"type": "integer", "minimum": 30, "maximum": 1000},
        "renderingHz": {"type": "integer", "minimum": 1, "maximum": 120},
        "tileReadyFrames": {"type": "integer", "minimum": 1, "maximum": 600},
        "privacyConsent": {"type": "boolean"},
        "camera": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height", "fps", "optics", "mount"],
          "properties": {
            "width": {"type": "integer", "minimum": 64, "maximum": 3840},
            "height": {"type": "integer", "minimum": 64, "maximum": 2160},
            "fps": {"type": "integer", "minimum": 1, "maximum": 60},
            "optics": {
              "type": "object",
              "additionalProperties": false,
              "required": ["focalLengthMm", "clippingRangeM"],
              "properties": {
                "focalLengthMm": {
                  "type": "number",
                  "minimum": 0.1,
                  "maximum": 1000
                },
                "clippingRangeM": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["near", "far"],
                  "properties": {
                    "near": {"type": "number", "minimum": 0.001, "maximum": 10000},
                    "far": {"type": "number", "minimum": 0.01, "maximum": 10000000}
                  }
                }
              }
            },
            "mount": {
              "type": "object",
              "additionalProperties": false,
              "required": ["translationM", "orientationWxyz"],
              "properties": {
                "translationM": {"$ref": "#/definitions/vector3"},
                "orientationWxyz": {"$ref": "#/definitions/quaternion"}
              }
            }
          }
        }
      }
    },
    "interactive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "progressDeadlineSeconds"],
      "properties": {
        "enabled": {"type": "boolean"},
        "progressDeadlineSeconds": {"type": "integer", "minimum": 600, "maximum": 3600}
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "sessionId",
        "exitAfterSeconds",
        "backoffLimit",
        "ttlSecondsAfterFinished"
      ],
      "properties": {
        "enabled": {"type": "boolean"},
        "sessionId": {"$ref": "#/definitions/identity"},
        "exitAfterSeconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 86400},
        "backoffLimit": {"type": "integer", "minimum": 0, "maximum": 10},
        "ttlSecondsAfterFinished": {"type": "integer", "minimum": 0}
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port"],
      "properties": {"port": {"const": 8802}}
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "mcp"],
      "properties": {
        "runtime": {"type": "object"},
        "mcp": {"type": "object"}
      }
    },
    "scheduling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeClassName", "nodeSelector", "tolerations", "affinity"],
      "properties": {
        "runtimeClassName": {"type": "string", "minLength": 1},
        "nodeSelector": {"type": "object", "additionalProperties": {"type": "string"}},
        "tolerations": {"type": "array", "items": {"type": "object"}},
        "affinity": {"type": "object"}
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "dnsNamespaceSelector"],
      "properties": {
        "enabled": {"type": "boolean"},
        "dnsNamespaceSelector": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    }
  },
  "definitions": {
    "identity": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "tag": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "pattern": "^$|^sha256:[a-f0-9]{64}$"}
      }
    },
    "vector3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": {"type": "number", "minimum": -100, "maximum": 100},
        "y": {"type": "number", "minimum": -100, "maximum": 100},
        "z": {"type": "number", "minimum": -100, "maximum": 100}
      }
    },
    "quaternion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["w", "x", "y", "z"],
      "properties": {
        "w": {"type": "number", "minimum": -1, "maximum": 1},
        "x": {"type": "number", "minimum": -1, "maximum": 1},
        "y": {"type": "number", "minimum": -1, "maximum": 1},
        "z": {"type": "number", "minimum": -1, "maximum": 1}
      }
    }
  }
}
