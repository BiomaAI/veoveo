{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["global", "images", "platform", "recordingForwarder", "telemetry", "simulation", "service", "persistence", "resources"],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["veoveoRegistry", "veoveoTag"],
      "properties": {
        "veoveoRegistry": {"type": "string"},
        "veoveoTag": {"type": "string"}
      }
    },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pullPolicy", "sim", "mcp", "forwarder"],
      "properties": {
        "pullPolicy": {"enum": ["Always", "IfNotPresent", "Never"]},
        "sim": {"$ref": "#/definitions/image"},
        "mcp": {"$ref": "#/definitions/image"},
        "forwarder": {"$ref": "#/definitions/image"}
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicBaseUrl", "surrealService", "surrealNamespace", "surrealDatabase", "surrealRuntimeSecret", "installationSecret", "artifactServiceUrl"],
      "properties": {
        "publicBaseUrl": {"type": "string", "pattern": "^(https://|http://(localhost|127\\.0\\.0\\.1|\\[::1\\])(:[0-9]+)?)"},
        "surrealService": {"type": "string", "minLength": 1},
        "surrealNamespace": {"type": "string", "minLength": 1},
        "surrealDatabase": {"type": "string", "minLength": 1},
        "surrealRuntimeSecret": {"type": "string", "minLength": 1},
        "installationSecret": {"type": "string", "minLength": 1},
        "artifactServiceUrl": {"type": "string", "pattern": "^http://"}
      }
    },
    "recordingForwarder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gatewayTransportUrl", "clientId", "keyId", "signingAlgorithm", "privateKey", "maximumQueueBytes", "persistence", "resources"],
      "properties": {
        "gatewayTransportUrl": {"type": "string", "pattern": "^https?://[A-Za-z0-9._:-]+/?$"},
        "clientId": {"type": "string", "minLength": 1},
        "keyId": {"type": "string", "minLength": 1},
        "signingAlgorithm": {"enum": ["rs256", "es256", "ed-dsa"]},
        "privateKey": {
          "type": "object",
          "additionalProperties": false,
          "required": ["existingSecret", "key"],
          "properties": {
            "existingSecret": {"type": "string", "minLength": 1},
            "key": {"type": "string", "minLength": 1}
          }
        },
        "maximumQueueBytes": {"type": "integer", "minimum": 8388608},
        "persistence": {"$ref": "#/definitions/persistence"},
        "resources": {"type": "object"}
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "endpoint"],
      "properties": {
        "enabled": {"type": "boolean"},
        "endpoint": {"type": "string", "pattern": "^http://"}
      }
    },
    "simulation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario", "maxVehicles", "connectRetries"],
      "properties": {
        "scenario": {"type": "string", "minLength": 1},
        "maxVehicles": {"type": "integer", "minimum": 1},
        "connectRetries": {"type": "integer", "minimum": 1}
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodePort"],
      "properties": {
        "nodePort": {"type": "integer", "minimum": 30000, "maximum": 32767}
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["size", "storageClass"],
      "properties": {
        "size": {"type": "string", "minLength": 1},
        "storageClass": {"type": "string"}
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sim", "mcp"],
      "properties": {
        "sim": {"type": "object"},
        "mcp": {"type": "object"}
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "tag": {"type": "string", "minLength": 1, "not": {"const": "latest"}}
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["size", "storageClass"],
      "properties": {
        "size": {"type": "string", "minLength": 1},
        "storageClass": {"type": "string"}
      }
    }
  }
}
