-- Authored map feature layers. SurrealDB is the canonical revision catalog;
-- DuckDB Spatial remains a rebuildable query projection.

DEFINE TABLE IF NOT EXISTS map_feature_layer SCHEMAFULL TYPE NORMAL CHANGEFEED 90d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE map_feature_layer TYPE array;
DEFINE FIELD IF NOT EXISTS tenant ON TABLE map_feature_layer TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS owner ON TABLE map_feature_layer TYPE record<principal>;
DEFINE FIELD IF NOT EXISTS work_context ON TABLE map_feature_layer TYPE record<work_context>;
DEFINE FIELD IF NOT EXISTS authority ON TABLE map_feature_layer TYPE object;
DEFINE FIELD IF NOT EXISTS authority.context_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS authority.membership ON TABLE map_feature_layer TYPE "viewer" | "contributor" | "custodian" | "owner";
DEFINE FIELD IF NOT EXISTS authority.policy_revision ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS authority.owner_kind ON TABLE map_feature_layer TYPE "principal" | "group";
DEFINE FIELD IF NOT EXISTS authority.owner_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS authority.initial_grants ON TABLE map_feature_layer TYPE array<object> DEFAULT [];
DEFINE FIELD IF NOT EXISTS authority.initial_grants.*.subject_kind ON TABLE map_feature_layer TYPE "principal" | "group";
DEFINE FIELD IF NOT EXISTS authority.initial_grants.*.subject_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS authority.initial_grants.*.permission ON TABLE map_feature_layer TYPE "read" | "write" | "admin";
DEFINE FIELD IF NOT EXISTS authority.classification ON TABLE map_feature_layer TYPE option<string>;
DEFINE FIELD IF NOT EXISTS authority.data_labels ON TABLE map_feature_layer TYPE array<string> DEFAULT [];
DEFINE FIELD IF NOT EXISTS authority.invocation_mode ON TABLE map_feature_layer TYPE "direct" | "delegated" | "automated";
DEFINE FIELD IF NOT EXISTS authority.initiator_key ON TABLE map_feature_layer TYPE option<string>;
DEFINE FIELD IF NOT EXISTS authority.delegation_id ON TABLE map_feature_layer TYPE option<string>;
DEFINE FIELD IF NOT EXISTS created_by_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS owner_kind ON TABLE map_feature_layer TYPE "principal" | "group";
DEFINE FIELD IF NOT EXISTS owner_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS layer_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS title ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS description ON TABLE map_feature_layer TYPE option<string>;
DEFINE FIELD IF NOT EXISTS content_class ON TABLE map_feature_layer TYPE "reference" | "named_locations" | "facilities" | "boundaries" | "network_candidate";
DEFINE FIELD IF NOT EXISTS schema_version ON TABLE map_feature_layer TYPE int ASSERT $value > 0;
DEFINE FIELD IF NOT EXISTS schema_revision_key ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS style_version ON TABLE map_feature_layer TYPE option<int>;
DEFINE FIELD IF NOT EXISTS style_revision_key ON TABLE map_feature_layer TYPE option<string>;
DEFINE FIELD IF NOT EXISTS revision ON TABLE map_feature_layer TYPE int ASSERT $value >= 0;
DEFINE FIELD IF NOT EXISTS classification ON TABLE map_feature_layer TYPE option<string>;
DEFINE FIELD IF NOT EXISTS data_labels ON TABLE map_feature_layer TYPE array<string> DEFAULT [];
DEFINE FIELD IF NOT EXISTS archived_at ON TABLE map_feature_layer TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS canonical_json ON TABLE map_feature_layer TYPE string;
DEFINE FIELD IF NOT EXISTS created_at ON TABLE map_feature_layer TYPE datetime;
DEFINE FIELD IF NOT EXISTS updated_at ON TABLE map_feature_layer TYPE datetime;
DEFINE INDEX IF NOT EXISTS map_feature_layer_tenant_key_unique ON TABLE map_feature_layer FIELDS tenant, layer_key UNIQUE;
DEFINE INDEX IF NOT EXISTS map_feature_layer_context_updated ON TABLE map_feature_layer FIELDS tenant, work_context, archived_at, updated_at;

DEFINE TABLE IF NOT EXISTS map_feature_schema_revision SCHEMAFULL TYPE NORMAL CHANGEFEED 90d INCLUDE ORIGINAL PERMISSIONS NONE;
