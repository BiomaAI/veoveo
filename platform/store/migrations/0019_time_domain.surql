DEFINE TABLE IF NOT EXISTS time_source SCHEMAFULL TYPE NORMAL CHANGEFEED 30d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE time_source TYPE string;
DEFINE FIELD IF NOT EXISTS tenant ON TABLE time_source TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS owner ON TABLE time_source TYPE record<principal>;
DEFINE FIELD IF NOT EXISTS source_key ON TABLE time_source TYPE string;
DEFINE FIELD IF NOT EXISTS name ON TABLE time_source TYPE string;
DEFINE FIELD IF NOT EXISTS dataset_kind ON TABLE time_source TYPE "tzdb" | "leap_seconds";
DEFINE FIELD IF NOT EXISTS source_url ON TABLE time_source TYPE string;
DEFINE FIELD IF NOT EXISTS expected_content_type ON TABLE time_source TYPE string;
DEFINE FIELD IF NOT EXISTS enabled ON TABLE time_source TYPE bool;
DEFINE FIELD IF NOT EXISTS canonical_json ON TABLE time_source TYPE string;
DEFINE FIELD IF NOT EXISTS record_version ON TABLE time_source TYPE int;
DEFINE FIELD IF NOT EXISTS created_at ON TABLE time_source TYPE datetime;
DEFINE FIELD IF NOT EXISTS updated_at ON TABLE time_source TYPE datetime;
DEFINE INDEX IF NOT EXISTS time_source_tenant_key_unique ON TABLE time_source FIELDS tenant, source_key UNIQUE;

