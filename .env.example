MEDIA_PROVIDER_API_KEY=
MEDIA_PROVIDER_WEBHOOK_SECRET=
# Google Maps Platform key with Map Tiles API access. View reads it only from
# the process environment and never places it in MCP input, logs, or cache keys.
GOOGLE_MAPS_API_KEY=
VEOVEO_IMAGE_TAG=0.1.0
# Use `offline` for an air-gapped installation with only bundled dependencies.
VEOVEO_CONNECTIVITY_MODE=connected

# SurrealDB 3.2.0 bootstrap credentials are used only by the one-shot
# installation-bootstrap container. Runtime services use the database user.
VEOVEO_SURREAL_ADMIN_USERNAME=root
VEOVEO_SURREAL_ADMIN_PASSWORD=
VEOVEO_SURREAL_RUNTIME_USERNAME=veoveo_runtime
VEOVEO_SURREAL_RUNTIME_PASSWORD=
VEOVEO_SURREAL_NAMESPACE=veoveo
VEOVEO_SURREAL_DATABASE=platform

# RustFS / external S3 credentials. The public endpoint must be reachable by
# authorized clients that receive a 60-second presigned download redirect.
VEOVEO_OBJECT_STORE_ACCESS_KEY=
VEOVEO_OBJECT_STORE_SECRET_KEY=
ARTIFACT_S3_PUBLIC_ENDPOINT=https://objects.enterprise.example

# Gateway-only base64 PKCS#8 Ed25519 private key and its public JWKS trust bundle.
# Generate the key with: openssl genpkey -algorithm ED25519 -out internal-signing.pem
VEOVEO_INTERNAL_SIGNING_KEY_DER_B64=
VEOVEO_INTERNAL_SIGNING_KEY_ID=veoveo-internal-1
# Wrap JSON in single quotes so dotenv and shell loaders preserve its quotes:
# VEOVEO_INTERNAL_TRUST_JWKS='{"keys":[...]}'
VEOVEO_INTERNAL_TRUST_JWKS=
VEOVEO_AUTHORIZATION_SERVER_PRIVATE_KEY_DER_B64=
VEOVEO_IDP_OIDC_CLIENT_SECRET=
# Gateway-only XChaCha20-Poly1305 key for the short-lived refresh successor
# delivery envelope. Do not reuse a signing key or the console session key.
# Canonical base64 encoding of exactly 32 random bytes: openssl rand -base64 32
VEOVEO_REFRESH_DELIVERY_KEY_B64=
VEOVEO_REFRESH_DELIVERY_WINDOW_SECONDS=5

# Canonical base64 encoding of exactly 32 random bytes: openssl rand -base64 32
VEOVEO_CONSOLE_SESSION_KEY=
VEOVEO_CONSOLE_OAUTH_CLIENT_ID=admin-console
VEOVEO_CONSOLE_OAUTH_RESOURCE=https://veoveo.example/mcp/admin
VEOVEO_CONSOLE_OAUTH_SCOPES="operator:use admin:manage"
PUBLIC_BASE_URL=https://veoveo.example

# Raw Rerun ingest is reachable only on the installation's private network at
# recording-hub:9876. Classification is descriptive; labels enforce clearance.
RECORDING_TENANT_KEY=enterprise
RECORDING_CLASSIFICATION=unclassified

# Optional Mapbox token for native Rerun map backgrounds. Veoveo keeps this
# provider setting canonical. A Rerun viewer running on the host needs it mapped
# to RERUN_MAPBOX_ACCESS_TOKEN; the SUMO showcase guide gives the exact command.
MAPBOX_ACCESS_TOKEN=

# Remote-managed Cloudflare Tunnel for the optional Bioma deployment. The API
# token needs Tunnel:Edit and DNS:Edit for the bioma.ai zone and account.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARED_TUNNEL_TOKEN=

# Ubuntu GPU deployment only. The config directory must contain catalog.json
# plus every referenced DeepStream inference/tracker config. TensorRT engines
# and label files live under the read-only model directory.
PERCEPTION_CONFIG_DIR=/opt/veoveo/perception/config
PERCEPTION_MODEL_DIR=/opt/veoveo/perception/models
