{
  "schemaVersion": "veoveo.io/deployment/v1",
  "name": "bioma",
  "registry": {
    "address": "k3d-veoveo-registry.localhost:5001",
    "localConfig": "../../deploy/local/k3d/registry.json"
  },
  "imageGroups": [
    "platform-full",
    "showcase-uav-sim"
  ],
  "kubernetes": {
    "context": "k3d-veoveo-bioma",
    "localCluster": {
      "name": "veoveo-bioma",
      "config": "k3d.yaml"
    }
  },
  "namespace": "veoveo",
  "resources": {
    "manifests": [
      "tunnel.yaml"
    ],
    "configMaps": [
      {
        "name": "bioma-gateway-control-plane",
        "files": {
          "gateway.json": "gateway.json",
          "recording-producer-jwks.json": "recording-producer-jwks.json"
        }
      }
    ],
    "secrets": [
      {
        "name": "veoveo-surreal-admin",
        "dataFromEnv": [
          {"key": "username", "environment": "VEOVEO_SURREAL_ADMIN_USERNAME"},
          {"key": "password", "environment": "VEOVEO_SURREAL_ADMIN_PASSWORD"}
        ]
      },
      {
        "name": "veoveo-surreal-runtime",
        "dataFromEnv": [
          {"key": "username", "environment": "VEOVEO_SURREAL_RUNTIME_USERNAME"},
          {"key": "password", "environment": "VEOVEO_SURREAL_RUNTIME_PASSWORD"}
        ]
      },
      {
        "name": "veoveo-installation-secrets",
        "dataFromEnv": [
          {"key": "internal-signing-key-der-b64", "environment": "VEOVEO_INTERNAL_SIGNING_KEY_DER_B64"},
          {"key": "internal-signing-key-id", "environment": "VEOVEO_INTERNAL_SIGNING_KEY_ID"},
          {"key": "internal-trust-jwks", "environment": "VEOVEO_INTERNAL_TRUST_JWKS", "format": "gatewayInternalTrustJwks"},
          {"key": "oidc-client-secret", "environment": "VEOVEO_IDP_OIDC_CLIENT_SECRET"},
          {"key": "authorization-server-private-key-der-b64", "environment": "VEOVEO_AUTHORIZATION_SERVER_PRIVATE_KEY_DER_B64"},
          {"key": "refresh-delivery-key-b64", "environment": "VEOVEO_REFRESH_DELIVERY_KEY_B64"},
          {"key": "console-session-key", "environment": "VEOVEO_CONSOLE_SESSION_KEY"},
          {"key": "object-store-access-key", "environment": "VEOVEO_OBJECT_STORE_ACCESS_KEY"},
          {"key": "object-store-secret-key", "environment": "VEOVEO_OBJECT_STORE_SECRET_KEY"},
          {"key": "media-provider-api-key", "environment": "MEDIA_PROVIDER_API_KEY"},
          {"key": "google-maps-api-key", "environment": "GOOGLE_MAPS_API_KEY"},
          {"key": "media-provider-webhook-secret", "environment": "MEDIA_PROVIDER_WEBHOOK_SECRET"}
        ]
      },
      {
        "name": "veoveo-uav-sim-secrets",
        "dataFromEnv": [
          {"key": "cesium-ion-access-token", "environment": "CESIUM_ION_ACCESS_TOKEN"}
        ]
      },
      {
        "name": "veoveo-recording-producer",
        "dataFromEnv": [
          {"key": "private-key.pem", "environment": "VEOVEO_RECORDING_PRODUCER_PRIVATE_KEY_PEM"}
        ]
      },
      {
        "name": "bioma-cloudflared",
        "dataFromEnv": [
          {"key": "token", "environment": "CLOUDFLARED_TUNNEL_TOKEN"}
        ]
      }
    ]
  },
  "releases": [
    {
      "name": "veoveo",
      "chart": "../../deploy/helm/veoveo",
      "values": ["values.yaml", "k3d-values.yaml"],
      "createNamespace": true,
      "timeoutSeconds": 720
    },
    {
      "name": "uav-sim",
      "chart": "../../showcase/uav-sim/deploy/helm",
      "values": ["uav-sim-values.yaml"],
      "createNamespace": false,
      "timeoutSeconds": 1800
    }
  ],
  "waitForDeployments": [
    "cloudflared"
  ]
}
