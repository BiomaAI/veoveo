-- Governed coordinate frames, temporal recordings, and durable agent wakes.

DEFINE TABLE IF NOT EXISTS frame SCHEMAFULL TYPE NORMAL CHANGEFEED 30d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE frame TYPE uuid DEFAULT rand::uuid();
DEFINE FIELD IF NOT EXISTS tenant ON TABLE frame TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS owner ON TABLE frame TYPE record<principal>;
DEFINE FIELD IF NOT EXISTS frame_key ON TABLE frame TYPE string;
DEFINE FIELD IF NOT EXISTS display_name ON TABLE frame TYPE string;
DEFINE FIELD IF NOT EXISTS definition ON TABLE frame TYPE object FLEXIBLE;
DEFINE FIELD IF NOT EXISTS proj_pipeline ON TABLE frame TYPE option<string>;
DEFINE FIELD IF NOT EXISTS classification ON TABLE frame TYPE string;
DEFINE FIELD IF NOT EXISTS labels ON TABLE frame TYPE array<string> DEFAULT [];
DEFINE FIELD IF NOT EXISTS created_at ON TABLE frame TYPE datetime DEFAULT time::now();
DEFINE FIELD IF NOT EXISTS updated_at ON TABLE frame TYPE datetime DEFAULT time::now();
DEFINE INDEX IF NOT EXISTS frame_tenant_key_unique ON TABLE frame FIELDS tenant, frame_key UNIQUE;
DEFINE INDEX IF NOT EXISTS frame_owner ON TABLE frame FIELDS tenant, owner;

DEFINE TABLE IF NOT EXISTS recording SCHEMAFULL TYPE NORMAL CHANGEFEED 30d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE recording TYPE uuid DEFAULT rand::uuid();
DEFINE FIELD IF NOT EXISTS tenant ON TABLE recording TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS owner ON TABLE recording TYPE record<principal>;
DEFINE FIELD IF NOT EXISTS application_id ON TABLE recording TYPE string;
DEFINE FIELD IF NOT EXISTS recording_key ON TABLE recording TYPE string;
DEFINE FIELD IF NOT EXISTS state ON TABLE recording TYPE "open" | "sealed" | "failed";
DEFINE FIELD IF NOT EXISTS classification ON TABLE recording TYPE string;
DEFINE FIELD IF NOT EXISTS labels ON TABLE recording TYPE array<string> DEFAULT [];
DEFINE FIELD IF NOT EXISTS metadata ON TABLE recording TYPE object FLEXIBLE DEFAULT {};
DEFINE FIELD IF NOT EXISTS started_at ON TABLE recording TYPE datetime;
DEFINE FIELD IF NOT EXISTS ended_at ON TABLE recording TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS created_at ON TABLE recording TYPE datetime DEFAULT time::now();
DEFINE INDEX IF NOT EXISTS recording_logical_unique ON TABLE recording FIELDS tenant, application_id, recording_key UNIQUE;
DEFINE INDEX IF NOT EXISTS recording_owner_started ON TABLE recording FIELDS tenant, owner, started_at;
DEFINE INDEX IF NOT EXISTS recording_state_started ON TABLE recording FIELDS tenant, state, started_at;

DEFINE TABLE IF NOT EXISTS segment SCHEMAFULL TYPE NORMAL CHANGEFEED 30d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE segment TYPE uuid DEFAULT rand::uuid();
DEFINE FIELD IF NOT EXISTS tenant ON TABLE segment TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS recording ON TABLE segment TYPE record<recording>;
DEFINE FIELD IF NOT EXISTS segment_key ON TABLE segment TYPE string;
DEFINE FIELD IF NOT EXISTS ordinal ON TABLE segment TYPE int ASSERT $value >= 0;
DEFINE FIELD IF NOT EXISTS object_key ON TABLE segment TYPE string;
DEFINE FIELD IF NOT EXISTS artifact ON TABLE segment TYPE option<record<artifact_occurrence>>;
DEFINE FIELD IF NOT EXISTS state ON TABLE segment TYPE "writing" | "ready" | "failed";
DEFINE FIELD IF NOT EXISTS start_time ON TABLE segment TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS end_time ON TABLE segment TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS byte_len ON TABLE segment TYPE int DEFAULT 0 ASSERT $value >= 0;
DEFINE FIELD IF NOT EXISTS sha256 ON TABLE segment TYPE option<string>;
DEFINE FIELD IF NOT EXISTS created_at ON TABLE segment TYPE datetime DEFAULT time::now();
DEFINE INDEX IF NOT EXISTS segment_recording_key_unique ON TABLE segment FIELDS recording, segment_key UNIQUE;
DEFINE INDEX IF NOT EXISTS segment_recording_ordinal_unique ON TABLE segment FIELDS recording, ordinal UNIQUE;
DEFINE INDEX IF NOT EXISTS segment_object_key_unique ON TABLE segment FIELDS object_key UNIQUE;
DEFINE INDEX IF NOT EXISTS segment_state_created ON TABLE segment FIELDS state, created_at;

DEFINE TABLE IF NOT EXISTS agent SCHEMAFULL TYPE NORMAL CHANGEFEED 30d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE agent TYPE uuid DEFAULT rand::uuid();
DEFINE FIELD IF NOT EXISTS tenant ON TABLE agent TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS agent_key ON TABLE agent TYPE string;
DEFINE FIELD IF NOT EXISTS display_name ON TABLE agent TYPE string;
DEFINE FIELD IF NOT EXISTS profile ON TABLE agent TYPE record<profile>;
DEFINE FIELD IF NOT EXISTS state ON TABLE agent TYPE "idle" | "running" | "waiting" | "disabled" | "failed";
DEFINE FIELD IF NOT EXISTS manifest ON TABLE agent TYPE object FLEXIBLE;
DEFINE FIELD IF NOT EXISTS memory_database ON TABLE agent TYPE string;
DEFINE FIELD IF NOT EXISTS last_episode_id ON TABLE agent TYPE option<string>;
DEFINE FIELD IF NOT EXISTS created_at ON TABLE agent TYPE datetime DEFAULT time::now();
DEFINE FIELD IF NOT EXISTS updated_at ON TABLE agent TYPE datetime DEFAULT time::now();
DEFINE INDEX IF NOT EXISTS agent_tenant_key_unique ON TABLE agent FIELDS tenant, agent_key UNIQUE;
DEFINE INDEX IF NOT EXISTS agent_tenant_state ON TABLE agent FIELDS tenant, state;

DEFINE TABLE IF NOT EXISTS wake SCHEMAFULL TYPE NORMAL CHANGEFEED 30d INCLUDE ORIGINAL PERMISSIONS NONE;
DEFINE FIELD IF NOT EXISTS id ON TABLE wake TYPE uuid DEFAULT rand::uuid();
DEFINE FIELD IF NOT EXISTS tenant ON TABLE wake TYPE record<tenant>;
DEFINE FIELD IF NOT EXISTS agent ON TABLE wake TYPE record<agent>;
DEFINE FIELD IF NOT EXISTS kind ON TABLE wake TYPE "task_result" | "resource_changed" | "timer" | "operator_message" | "elicitation";
DEFINE FIELD IF NOT EXISTS state ON TABLE wake TYPE "pending" | "claimed" | "acked" | "failed" DEFAULT "pending";
DEFINE FIELD IF NOT EXISTS dedupe_key ON TABLE wake TYPE option<string>;
DEFINE FIELD IF NOT EXISTS payload ON TABLE wake TYPE object FLEXIBLE;
DEFINE FIELD IF NOT EXISTS available_at ON TABLE wake TYPE datetime DEFAULT time::now();
DEFINE FIELD IF NOT EXISTS claimed_by ON TABLE wake TYPE option<string>;
DEFINE FIELD IF NOT EXISTS claimed_at ON TABLE wake TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS attempts ON TABLE wake TYPE int DEFAULT 0 ASSERT $value >= 0;
DEFINE FIELD IF NOT EXISTS acked_at ON TABLE wake TYPE option<datetime>;
DEFINE FIELD IF NOT EXISTS last_error ON TABLE wake TYPE option<string>;
DEFINE FIELD IF NOT EXISTS created_at ON TABLE wake TYPE datetime DEFAULT time::now();
DEFINE INDEX IF NOT EXISTS wake_agent_available ON TABLE wake FIELDS agent, state, available_at;
DEFINE INDEX IF NOT EXISTS wake_claim_expiry ON TABLE wake FIELDS state, claimed_at;
DEFINE INDEX IF NOT EXISTS wake_tenant_dedupe ON TABLE wake FIELDS tenant, agent, dedupe_key;
