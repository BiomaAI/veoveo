{
	admin off
	auto_https off
}

:8080 {
	log {
		output stdout
		format console
	}

	handle /console* {
		reverse_proxy console-bff:8786
	}

	handle /auth* {
		reverse_proxy console-bff:8786
	}

	# Public bearer links redeem at the private artifact service. Authorized
	# downloads enter through the gateway and are checked against profile policy.
	handle /s/* {
		# The path contains a bearer secret. Redemption is audited by the
		# artifact service without recording the raw token.
		log_skip
		reverse_proxy artifact-service:8790
	}

	handle /artifacts/* {
		reverse_proxy mcp-gateway:8788
	}

	handle /mcp* {
		reverse_proxy mcp-gateway:8788
	}

	handle /oauth* {
		reverse_proxy mcp-gateway:8788
	}

	handle /.well-known/oauth-* {
		reverse_proxy mcp-gateway:8788
	}

	handle /admin* {
		reverse_proxy mcp-gateway:8788
	}

	handle /healthz {
		reverse_proxy mcp-gateway:8788
	}

	handle /readyz {
		reverse_proxy mcp-gateway:8788
	}

	handle /media/webhooks* {
		reverse_proxy media-mcp:8787
	}

	handle /media/files* {
		reverse_proxy media-mcp:8787
	}

	respond /media/mcp* 404
	respond /timeseries/mcp* 404
	respond /optimization/mcp* 404
	respond /frames/mcp* 404
	respond /map/mcp* 404
	respond /perception/mcp* 404
	respond /duckdb/mcp* 404
	respond /charts/mcp* 404
	respond 404
}
