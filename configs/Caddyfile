{
	admin off
	auto_https off
}

:8080 {
	log {
		output stdout
		format console
	}

	handle /mcp* {
		reverse_proxy mcp-gateway:8788
	}

	handle /oauth* {
		reverse_proxy mcp-gateway:8788
	}

	handle /.well-known/oauth-* {
		reverse_proxy mcp-gateway:8788
	}

	handle /admin* {
		reverse_proxy mcp-gateway:8788
	}

	handle /healthz {
		reverse_proxy mcp-gateway:8788
	}

	handle /readyz {
		reverse_proxy mcp-gateway:8788
	}

	handle /media/webhooks* {
		reverse_proxy media-mcp:8787
	}

	handle /media/files* {
		reverse_proxy media-mcp:8787
	}

	handle /media/artifacts* {
		reverse_proxy media-mcp:8787
	}

	handle /media/healthz {
		reverse_proxy media-mcp:8787
	}

	handle /timeseries/artifacts* {
		reverse_proxy timeseries-mcp:8789
	}

	handle /timeseries/healthz {
		reverse_proxy timeseries-mcp:8789
	}

	handle /duckdb/artifacts* {
		reverse_proxy duckdb-mcp:8791
	}

	handle /duckdb/healthz {
		reverse_proxy duckdb-mcp:8791
	}

	respond /media/mcp* 404
	respond /timeseries/mcp* 404
	respond /duckdb/mcp* 404
	respond 404
}
